import { useEffect, useState } from 'react'
import Layout from '../components/Layout'
import axios from 'axios'

const API = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000'

export default function Banks() {
  const [banks, setBanks] = useState([])
  const [filter, setFilter] = useState('all')
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    axios.get(`${API}/api/banks/`)
      .then(r => setBanks(r.data))
      .catch(() => setBanks([]))
      .finally(() => setLoading(false))
  }, [])

  const filtered = filter === 'all' ? banks : banks.filter(b => b.type === filter)

  const typeLabel = { bank: 'Банк', mfo: 'МФО', nko: 'НКО' }
  const typeColor = { bank: '#dbeafe', mfo: '#d1fae5', nko: '#fce7f3' }
  const typeTextColor = { bank: '#1e40af', mfo: '#065f46', nko: '#9d174d' }

  return (
    <Layout title="Банки Таджикистана">
      <div style={{ maxWidth: 1200, margin: '0 auto', padding: '2rem 1rem' }}>
        <h1 style={{ margin: '0 0 0.5rem', fontSize: 28 }}>Банки и МФО Таджикистана</h1>
        <p style={{ color: '#6b7280', margin: '0 0 1.5rem' }}>
          Все кредитные организации с лицензией НБТ · {banks.length} организаций
        </p>

        {/* Filter tabs */}
        <div style={{ display: 'flex', gap: 8, marginBottom: '1.5rem' }}>
          {[['all', 'Все'], ['bank', 'Банки'], ['mfo', 'МФО'], ['nko', 'НКО']].map(([val, label]) => (
            <button key={val} onClick={() => setFilter(val)} style={{
              padding: '8px 20px', borderRadius: 20,
              border: filter === val ? 'none' : '1px solid #d1d5db',
              background: filter === val ? '#1a56db' : 'white',
              color: filter === val ? 'white' : '#374151',
              cursor: 'pointer', fontWeight: 500, fontSize: 14
            }}>{label}</button>
          ))}
        </div>

        {loading ? (
          <div style={{ textAlign: 'center', padding: '3rem', color: '#6b7280' }}>Загрузка...</div>
        ) : (
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill,minmax(320px,1fr))', gap: 16 }}>
            {filtered.map(bank => (
              <div key={bank.id} className="card" style={{ padding: '1.25rem' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 12 }}>
                  <div style={{ flex: 1 }}>
                    <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 4 }}>
                      <span style={{
                        background: typeColor[bank.type] || '#f3f4f6',
                        color: typeTextColor[bank.type] || '#374151',
                        padding: '2px 10px', borderRadius: 20, fontSize: 12, fontWeight: 500
                      }}>{typeLabel[bank.type] || bank.type}</span>
                    </div>
                    <div style={{ fontWeight: 700, fontSize: 16, lineHeight: 1.3 }}>{bank.name}</div>
                  </div>
                  {bank.products_count > 0 && (
                    <div style={{ background: '#eff6ff', borderRadius: 8, padding: '4px 10px', textAlign: 'center', flexShrink: 0 }}>
                      <div style={{ fontSize: 18, fontWeight: 700, color: '#1a56db' }}>{bank.products_count}</div>
                      <div style={{ fontSize: 11, color: '#6b7280' }}>продуктов</div>
                    </div>
                  )}
                </div>

                <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontSize: 13 }}>
                  {bank.website && (
                    <div style={{ display: 'flex', gap: 8, color: '#6b7280' }}>
                      <span>🌐</span>
                      <a href={bank.website} target="_blank" rel="noopener noreferrer"
                        style={{ color: '#1a56db', textDecoration: 'none' }}>{bank.website}</a>
                    </div>
                  )}
                  {bank.phone && (
                    <div style={{ display: 'flex', gap: 8, color: '#6b7280' }}>
                      <span>📞</span><span>{bank.phone}</span>
                    </div>
                  )}
                  {bank.founded_year && (
                    <div style={{ display: 'flex', gap: 8, color: '#6b7280' }}>
                      <span>📅</span><span>Основан в {bank.founded_year} году</span>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </Layout>
  )
}
